<div class="cover-room-index">
  <div class="container d-flex flex-column align-items-center">
    <div class="row mt-5">
      <h1 class="font-weight-normal">チャット一覧</h1>
    </div>
  <div class="row mt-5 w-50">
    <% @another_entries.each do |entry| %>
    <div class="one-post-card mt-3">
        <div class="d-flex">
          <%= link_to user_path(entry.user) do %>
          <% if entry.user.profile_image.attached? %>
            <%= image_tag entry.user.profile_image, size: '50x50', class: "mt-3 ml-3 profile-img" %>
          <% else %>
            <%= image_tag "no_image.svg", size: '50x50', class: "mt-3 ml-3 profile-img" %>
          <% end %>
          <p class="caption h4 mt-4"><%= entry.user.name %></p>
          <% end %>
          <p><%= entry.room.messages.last&.message %></p>
        </div>
    </div>
    <% end %>
  </div>
</div>


